			"type": "string"
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-extract JWT token from response if present",
					"if (pm.response.headers.get('Set-Cookie')) {",
					"    var cookies = pm.response.headers.get('Set-Cookie');",
					"    var jwtMatch = cookies.match(/JWT_TOKEN=([^;]+)/);",
					"    if (jwtMatch) {",
					"        pm.collectionVariables.set('jwt_token', jwtMatch[1]);",
					"    }",
					"}"
				]
			}
		}
	]
